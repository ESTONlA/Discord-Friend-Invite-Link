function getToken(){
 return new Promise(resolve => {
  const old = window.XMLHttpRequest

  window.XMLHttpRequest = class extends old{
   constructor(){
    super()
    const set = this.setRequestHeader

    this.setRequestHeader = function(key, value){
     if(key === "Authorization"){
      resolve(value)
      window.XMLHttpRequest = old
     }

     set.apply(this, arguments)
    }
   }
  }
 })
}

