function inject(){
 const existing = document.getElementById("efi_root")

 if(existing){
  existing.remove()
 }

 const wrapper = document.createElement("div")
 wrapper.id = "efi_root"
 wrapper.innerHTML = `${html}<style>${css}</style>`
 document.body.appendChild(wrapper)

 root = wrapper
 div = document.getElementById("efi_window")

 document.getElementById("efi_header").addEventListener("mousedown", mouseDown)
 document.getElementById("efi_select").addEventListener("change", updateSelection)
 window.addEventListener("mouseup", mouseUp)
 window.addEventListener("mousemove", move)

 document.getElementById("efi_close").onclick = removeUI
 document.getElementById("efi_create").onclick = createInvite
 document.getElementById("efi_info").onclick = infoInvite
 document.getElementById("efi_delete").onclick = deleteInvites

 setStatus("Waiting for session", "warn")
 setEmptyState("Connecting", "The panel will load invites after Discord sends an authenticated request.")

 getToken().then(t => {
  token = t
  setStatus("Connected", "success")
  fetchInvites()
 }).catch(() => {
  setStatus("Token unavailable", "error")
  setEmptyState("Unable to connect", "Discord did not expose an authorization token to the script.")
 })
}

function mouseDown(e){
 if(e.target.id === "efi_close"){
  return
 }

 isDragging = true
 offsetLeft = div.offsetLeft - e.clientX
 offsetTop = div.offsetTop - e.clientY
}

function mouseUp(){
 isDragging = false
}

function move(e){
 if(!isDragging){
  return
 }

 div.style.left = `${Math.max(8, e.clientX + offsetLeft)}px`
 div.style.top = `${Math.max(8, e.clientY + offsetTop)}px`
}

function updateSelection(){
 const select = document.getElementById("efi_select")
 const infoButton = document.getElementById("efi_info")
 const value = select.value || "None"

 document.getElementById("efi_current").textContent = value
 infoButton.disabled = !select.value || select.value === "none"
}

function setStatus(text, tone = "neutral"){
 const status = document.getElementById("efi_status")
 status.textContent = text
 status.dataset.tone = tone
}

function setEmptyState(title, copy){
 const out = document.getElementById("efi_output")

 out.innerHTML = `
  <div class="efi_empty">
    <div class="efi_empty_title">${escapeHtml(title)}</div>
    <div class="efi_empty_copy">${escapeHtml(copy)}</div>
  </div>
 `
}

function setOutputCard(title, copy, body){
 const out = document.getElementById("efi_output")

 out.innerHTML = `
  <div class="efi_output_stack">
    <div>
      <div class="efi_output_title">${escapeHtml(title)}</div>
      <div class="efi_output_copy">${escapeHtml(copy)}</div>
    </div>
    ${body}
  </div>
 `
}

function formatLink(code){
 const url = `https://discord.gg/${code}`
 return `<a class="efi_output_link" href="${url}" target="_blank" rel="noreferrer">${escapeHtml(url)}</a>`
}

function formatUses(invite){
 if(invite.max_uses === 0){
  return `${invite.uses}/inf`
 }

 return `${invite.uses}/${invite.max_uses}`
}

function formatExpiry(invite){
 if(invite.max_age === 0){
  return "Never"
 }

 const hours = Math.round(invite.max_age / 3600)
 return `${hours}h`
}

function escapeHtml(value){
 return String(value).replace(/[&<>"']/g, char => {
  if(char === "&"){
   return "&amp;"
  }

  if(char === "<"){
   return "&lt;"
  }

  if(char === ">"){
   return "&gt;"
  }

  if(char === `"`){
   return "&quot;"
  }

  return "&#39;"
 })
}

async function createInvite(){
 const createButton = document.getElementById("efi_create")

 try{
  createButton.disabled = true
  setStatus("Creating invite", "warn")
  setEmptyState("Creating invite", "Requesting a fresh friend invite from Discord.")

  const response = await fetch("https://discord.com/api/v9/users/@me/invites", {
   method:"POST",
   headers:{
    "Authorization":token,
    "Content-Type":"application/json"
   },
   body:"{}"
  })

  const invite = await response.json()

  if(!response.ok || !invite.code){
   throw new Error(invite.message || "Discord did not return a valid invite.")
  }

  setStatus("Invite created", "success")
  setOutputCard(
   "Invite created",
   "Share or copy the new friend invite below.",
   formatLink(invite.code)
  )

  await fetchInvites(invite.code)
 }catch(error){
  setStatus("Create failed", "error")
  setEmptyState("Could not create invite", error.message || "Discord rejected the create request.")
 }finally{
  createButton.disabled = false
 }
}

async function fetchInvites(preferredCode){
 try{
  const response = await fetch("https://discord.com/api/v9/users/@me/invites", {
   headers:{
    "Authorization":token
   }
  })

  const list = await response.json()

  if(!response.ok || !Array.isArray(list)){
   throw new Error("Discord did not return a valid invite list.")
  }

  const select = document.getElementById("efi_select")
  const count = document.getElementById("efi_count")
  const infoButton = document.getElementById("efi_info")

  select.innerHTML = ""
  count.textContent = String(list.length)

  if(!list.length){
   const option = document.createElement("option")
   option.value = "none"
   option.textContent = "No active invites"
   select.appendChild(option)
   select.disabled = true
   infoButton.disabled = true
   document.getElementById("efi_current").textContent = "None"
   setStatus("No invites found", "warn")
   setEmptyState("No active invites", "Create a new invite to populate this list.")
   return
  }

  select.disabled = false

  list.forEach(invite => {
   const option = document.createElement("option")
   option.value = invite.code
   option.textContent = `discord.gg/${invite.code}`
   select.appendChild(option)
  })

  if(preferredCode && list.some(invite => invite.code === preferredCode)){
   select.value = preferredCode
  }

  updateSelection()

  if(!preferredCode){
   setStatus("Invites synced", "success")
   setOutputCard(
    "Invites loaded",
    "Choose an invite to inspect it or create a fresh one.",
    formatLink(select.value)
   )
  }
 }catch(error){
  setStatus("Load failed", "error")
  setEmptyState("Unable to load invites", error.message || "Discord rejected the invite list request.")
 }
}

async function infoInvite(){
 const select = document.getElementById("efi_select")
 const code = select.value

 if(!code || code === "none"){
  setStatus("No invite selected", "warn")
  setEmptyState("Nothing selected", "Choose an invite from the dropdown first.")
  return
 }

 try{
  setStatus("Loading details", "warn")

  const response = await fetch("https://discord.com/api/v9/users/@me/invites", {
   headers:{
    "Authorization":token
   }
  })

  const list = await response.json()

  if(!response.ok || !Array.isArray(list)){
   throw new Error("Discord did not return invite details.")
  }

  const invite = list.find(item => item.code === code)

  if(!invite){
   setStatus("Invite missing", "error")
   setEmptyState("Invite not found", "The selected invite no longer exists. Refresh or create another one.")
   await fetchInvites()
   return
  }

  setStatus("Invite details", "success")
  setOutputCard(
   "Invite details",
   "Live information for the selected friend invite.",
   `
    <div class="efi_detail_grid">
      <div class="efi_detail">
        <div class="efi_detail_label">Code</div>
        <div class="efi_detail_value">${escapeHtml(invite.code)}</div>
      </div>
      <div class="efi_detail">
        <div class="efi_detail_label">Uses</div>
        <div class="efi_detail_value">${escapeHtml(formatUses(invite))}</div>
      </div>
      <div class="efi_detail">
        <div class="efi_detail_label">Expires</div>
        <div class="efi_detail_value">${escapeHtml(formatExpiry(invite))}</div>
      </div>
    </div>
    ${formatLink(invite.code)}
   `
  )
 }catch(error){
  setStatus("Details failed", "error")
  setEmptyState("Could not load invite details", error.message || "Discord rejected the info request.")
 }
}

async function deleteInvites(){
 const button = document.getElementById("efi_delete")

 try{
  button.disabled = true
  setStatus("Deleting invites", "warn")
  setEmptyState("Deleting invites", "Removing every active friend invite from your account.")

  const response = await fetch("https://discord.com/api/v9/users/@me/invites", {
   method:"DELETE",
   headers:{
    "Authorization":token
   }
  })

  if(!response.ok){
   const failure = await response.json().catch(() => ({}))
   throw new Error(failure.message || "Discord rejected the delete request.")
  }

  setStatus("Invites deleted", "success")
  setEmptyState("All invites deleted", "Your active friend invite list is now empty.")
  await fetchInvites()
 }catch(error){
  setStatus("Delete failed", "error")
  setEmptyState("Could not delete invites", error.message || "Discord rejected the delete request.")
 }finally{
  button.disabled = false
 }
}

